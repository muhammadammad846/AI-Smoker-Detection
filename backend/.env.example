# Server
PORT=3000
NODE_ENV=development

# Firebase (for deployed backend use SERVICE_ACCOUNT_JSON; local can use ServiceAccount.json file)
# Paste full JSON of your Firebase service account key (single line or multiline)
# SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Match backend ServiceAccount project_id (e.g. cctv-smoking-detection.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=cctv-smoking-detection.firebasestorage.app

# Production: restrict CORS and Socket.io to your app origin(s)
# CORS_ORIGIN=https://yourapp.com,https://expo.io
# FRONTEND_URL=https://yourapp.com

# AI detection tuning (optional; defaults are tuned for fewer false positives)
# DETECTION_CONF_THRESHOLD=0.55   # YOLO min confidence to count as detection
# CHALLAN_CONF_THRESHOLD=0.6      # Min confidence to auto-generate challan (Node + Python)
# FACE_MATCH_THRESHOLD=0.55       # Face match max distance (lower = stricter)
# MIN_FACE_WIDTH=60               # Min face size for recognition (pixels)
# MIN_FACE_HEIGHT=60
