rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================
    // USERS COLLECTION
    // ===========================
    match /users/{userId} {
      // Logged-in users can read (app uses this for roles; restrict to own doc if needed)
      allow read: if request.auth != null;

      // Only admins can write user documents
      allow write: if isAdmin();
    }

    // ===========================
    // CHALLANS COLLECTION
    // ===========================
    match /challans/{challanId} {
      // Students: own challans only; admins/security_heads/guards: all
      allow read: if request.auth != null &&
        (resource.data.studentId == request.auth.uid || isAdmin() || isSecurityHead() || isGuard());

      allow create, update, delete: if isAdmin();
      allow create, update: if isSecurityHead();
    }

    // ===========================
    // DEFAULT DENY
    // ===========================
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ===========================
    // HELPER FUNCTIONS
    // ===========================
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSecurityHead() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'security_head';
    }

    function isGuard() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'guard';
    }
  }
}

